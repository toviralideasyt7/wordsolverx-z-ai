{
	"name": "wordsolverx-svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"colordle:update-data": "node scripts/update-colordle-data.mjs",
		"canuckle:update-data": "node scripts/update-canuckle-data.mjs",
		"countryle:update-data": "node scripts/update-countryle-data.mjs",
		"framed:update-data": "node scripts/update-framed-data.mjs",
		"spotle:update-data": "node scripts/update-spotle-data.mjs",
		"worgle:update-data": "node scripts/update-worgle-data.mjs",
		"articles:generate": "node scripts/generate-daily-articles.mjs",
		"articles:generate:all-current-windows": "node scripts/generate-daily-articles-batch.mjs",
		"data:update:retry-failed": "node scripts/update-retry-failed-data.mjs",
		"data:update:backup-9am-ist": "node scripts/update-retry-failed-data.mjs",
		"data:update": "npm run colordle:update-data && npm run canuckle:update-data && npm run countryle:update-data && npm run framed:update-data && npm run spotle:update-data && npm run worgle:update-data",
		"dev": "vite dev",
		"build": "node scripts/build-cloudflare.mjs",
		"build:pages": "node scripts/build-pages.mjs",
		"deploy": "npm run data:update && npm run articles:generate && npm run build && wrangler deploy --config wrangler.jsonc",
		"deploy:pages": "npm run data:update && npm run articles:generate && npm run build:pages && wrangler pages deploy build/pages --project-name wordsolverx-z-ai --config wrangler.pages.jsonc",
		"preview": "vite preview",
		"preview:cf": "npm run build && wrangler dev --config wrangler.jsonc",
		"pagespeed:capture:before": "node scripts/pagespeed-capture-before.mjs",
		"pagespeed:analyze:before": "node scripts/pagespeed-analyze-before.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.2.0",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/crypto-js": "^4.2.2",
		"@types/node": "^25.3.0",
		"@types/seedrandom": "^3.0.8",
		"@vitest/ui": "^4.0.18",
		"autoprefixer": "^10.4.24",
		"eslint": "^10.0.0",
		"eslint-plugin-svelte": "^3.15.0",
		"fast-check": "^4.5.3",
		"jsdom": "^28.1.0",
		"postcss": "^8.5.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.2.0",
		"terser": "^5.46.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"wrangler": "^4.66.0"
	},
	"dependencies": {
		"color-name-list": "^14.32.0",
		"color-space": "^2.3.2",
		"crypto-js": "^4.2.0",
		"date-fns": "^4.1.0",
		"delta-e": "^0.0.8",
		"seedrandom": "^3.0.5",
		"svelte-5-french-toast": "^2.0.6"
	}
}
